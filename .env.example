# Cargo Provisions — client environment (browser-exposed; anon key ONLY)
# Copy to .env and fill in. NEVER put the Supabase service-role key here.
VITE_SUPABASE_URL=https://<your-provisions-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>
VITE_TURNSTILE_SITE_KEY=<cloudflare-turnstile-site-key>

# Edge Function secrets are set in Supabase (NOT here, NOT VITE_*):
#   SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
# These are usually auto-present in the project's functions runtime.
